# AI Book Reel Studio - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=development
APP_NAME="AI Book Reel Studio"
APP_VERSION=1.0.0
APP_PORT=3000
FRONTEND_PORT=5173

# ============================================================================
# DATABASE SETTINGS
# ============================================================================
# SQLite (local development - no setup required)
DATABASE_URL=sqlite:./data/app.db
DB_ENCRYPTION_KEY=your-32-char-encryption-key-here

# PostgreSQL (production - uncomment to use)
# DATABASE_URL=postgresql://user:password@localhost:5432/book_reel_studio
# DB_SSL=false

# ============================================================================
# REDIS SETTINGS (for job queues)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# For cloud Redis:
# REDIS_URL=redis://:password@host:port/db

# ============================================================================
# AI / MACHINE LEARNING SETTINGS
# ============================================================================
# Privacy mode: local | hybrid | cloud
AI_PRIVACY_MODE=local

# Local models path
MODELS_PATH=./resources/models

# Model cache size (GB)
MODEL_CACHE_SIZE=5

# Auto-update models on startup
AUTO_UPDATE_MODELS=false

# Cloud AI APIs (optional - only used in hybrid/cloud mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
HUGGINGFACE_API_KEY=

# ============================================================================
# FFMPEG SETTINGS
# ============================================================================
# FFmpeg binary path (auto-detected if empty)
FFMPEG_PATH=
FFPROBE_PATH=

# Hardware acceleration: auto | nvenc | qsv | vaapi | none
HW_ACCELERATION=auto

# ============================================================================
# RENDERING SETTINGS
# ============================================================================
DEFAULT_RESOLUTION=1080p
DEFAULT_FPS=30
DEFAULT_ASPECT_RATIO=9:16
HW_ACCELERATION_ENABLED=true
MAX_CONCURRENT_RENDERS=1

# ============================================================================
# STORAGE SETTINGS
# ============================================================================
DATA_PATH=./data
EXPORTS_PATH=./data/exports
TEMP_PATH=./data/temp
MODELS_PATH=./resources/models
ASSETS_PATH=./resources/assets

# Auto-cleanup temp files (hours)
TEMP_CLEANUP_HOURS=24

# Encrypt temporary files
ENCRYPT_TEMP_FILES=true

# ============================================================================
# PRIVACY SETTINGS
# ============================================================================
# Privacy mode: local | hybrid | cloud
PRIVACY_MODE=local

# Auto-delete temp files after export
AUTO_CLEANUP_TEMP=true

# Cleanup interval (hours)
CLEANUP_INTERVAL_HOURS=24

# Anonymous usage analytics (opt-in)
TELEMETRY_ENABLED=false

# Allow model training on user data (requires explicit consent)
ALLOW_TRAINING_DATA=false

# ============================================================================
# EXPORT SETTINGS
# ============================================================================
DEFAULT_EXPORT_PRESET=instagram
EXPORT_PRESETS=instagram,high,4k

# ============================================================================
# BLOCKCHAIN SETTINGS (verification only)
# ============================================================================
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=local
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_PRIVATE_KEY=

# ============================================================================
# EMAIL SETTINGS (for notifications)
# ============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AI Book Reel Studio <noreply@bookreelstudio.com>"

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# Master encryption key (32 chars minimum)
MASTER_ENCRYPTION_KEY=your-super-secret-32-char-minimum-key

# JWT secret for authentication
JWT_SECRET=your-jwt-secret-here

# Session secret
SESSION_SECRET=your-session-secret-here

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Sentry (error tracking - optional)
SENTRY_DSN=

# ============================================================================
# EXTERNAL SERVICES (optional)
# ============================================================================
# Cloud storage for backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_KEY_FILE=

# Azure
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
# Enable hot reload
HOT_RELOAD=true

# Open browser on startup
OPEN_BROWSER=true

# Verbose logging
VERBOSE=false

# Mock AI responses (for testing without models)
MOCK_AI_RESPONSES=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_4K_EXPORT=true
FEATURE_HDR_EXPORT=false
FEATURE_BLOCKCHAIN_VERIFICATION=false
FEATURE_CUSTOM_MODELS=false
FEATURE_TEAM_COLLABORATION=false
FEATURE_ANALYTICS_DASHBOARD=false