{
  "name": "ai-book-reel-studio",
  "version": "1.0.0",
  "description": "Privacy-first AI-powered book reel creation studio",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "node scripts/startup/main.js",
    "start:prod": "npm run build && node dist/main/index.js",
    "start:dev": "node scripts/startup/main.js --dev",
    "start:auto": "node scripts/startup/main.js --auto",
    "start:skip-checks": "node scripts/startup/main.js --skip-checks",
    "start:no-browser": "node scripts/startup/main.js --no-browser",
    "start:checks": "node scripts/checks/system-checks.js",
    "start:first-run": "node scripts/init/first-run.js",
    "start:recovery": "node scripts/startup/recovery.js",
    "start:dashboard": "node scripts/startup/dashboard.js",
    "start:browser": "node scripts/startup/browser-launcher.js",
    "start:model-check": "node scripts/check-models.js",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsx watch src/main/index.ts",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc",
    "build:renderer": "vite build",
    "build:all": "npm run build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "db:migrate": "tsx src/main/services/database.ts migrate",
    "db:seed": "tsx src/main/services/database.ts seed",
    "models:download": "tsx scripts/download-models.js",
    "models:list": "tsx scripts/list-models.js",
    "models:check": "tsx scripts/check-models.js",
    "models:download-all": "tsx scripts/download-models.js --all",
    "models:warmup": "tsx scripts/warmup-models.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "better-sqlite3": "^9.4.3",
    "bullmq": "^5.8.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-updater": "^6.1.7",
    "fluent-ffmpeg": "^2.1.2",
    "immer": "^11.1.11",
    "ioredis": "^5.3.2",
    "lucide-react": "^0.344.0",
    "onnxruntime-node": "^1.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^16.0.0",
    "react-hook-form": "^7.51.0",
    "react-hot-toast": "^2.6.0",
    "sodium-native": "^4.0.5",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.58",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.2.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^7.0.2",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  },
  "build": {
    "appId": "com.thebookclub.aibookreelstudio",
    "productName": "AI Book Reel Studio",
    "copyright": "Copyright © 2026 The Book Club",
    "directories": {
      "output": "dist/electron",
      "buildResources": "build"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "preload/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "thebookclub",
      "repo": "ai-book-reel-studio"
    }
  }
}
